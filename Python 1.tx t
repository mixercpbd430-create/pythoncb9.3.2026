Quản lý tài khoản ngân hàng
class BankAccount:
    def __init__(self, owner, balance=0):
        self.owner = owner
        self.balance = balance

    def deposit(self, amount):
        try:
            if amount <= 0:
                raise ValueError("Số tiền gửi phải lớn hơn 0.")
            self.balance += amount
            print(f"Đã gửi {amount}. Số dư hiện tại là: {self.balance}")
        except ValueError as e:
            print(f"Lỗi: {e}")
    
    def withdraw(self, amount):
        try:
            if amount <= 0:
                raise ValueError("Số tiền rút phải lớn hơn 0.")
            if amount > self.balance:
                raise ValueError("Không đủ số dư để rút.")
            self.balance -= amount
            print(f"Đã rút {amount}. Số dư hiện tại là: {self.balance}")
        except ValueError as e:
            print(f"Lỗi: {e}")
    
    def check_balance(self):
        print(f"Số dư tài khoản của {self.owner} là: {self.balance}")


# Tạo tài khoản ngân hàng
account = BankAccount("Alice", 1000)

# Các hành động của người dùng
while True:
    print("\n1. Nạp tiền")
    print("2. Rút tiền")
    print("3. Kiểm tra số dư")
    print("4. Thoát")

    choice = input("Chọn hành động: ")

    if choice == "1":
        try:
            amount = float(input("Nhập số tiền muốn gửi: "))
            account.deposit(amount)
        except ValueError:
            print("Lỗi: Vui lòng nhập một số hợp lệ.")
    
    elif choice == "2":
        try:
            amount = float(input("Nhập số tiền muốn rút: "))
            account.withdraw(amount)
        except ValueError:
            print("Lỗi: Vui lòng nhập một số hợp lệ.")
    
    elif choice == "3":
        account.check_balance()
    
    elif choice == "4":
        print("Thoát chương trình.")
        break
    
    else:
        print("Lựa chọn không hợp lệ. Vui lòng chọn lại.")
Giải thích chương trình:

    Lớp BankAccount:
        Phương thức __init__ khởi tạo tài khoản với tên chủ sở hữu và số dư (mặc định là 0).
        Phương thức deposit dùng để nạp tiền vào tài khoản. Nếu số tiền nạp vào không hợp lệ (<= 0), chương trình sẽ raise một ngoại lệ ValueError để thông báo cho người dùng.
        Phương thức withdraw dùng để rút tiền từ tài khoản. Nó kiểm tra số tiền rút có hợp lệ hay không (số tiền phải lớn hơn 0 và không vượt quá số dư tài khoản).
        Phương thức check_balance in ra số dư hiện tại của tài khoản.

    Xử lý ngoại lệ:
        Trong phương thức deposit và withdraw, chúng ta sử dụng try-except để bắt các lỗi liên quan đến giá trị không hợp lệ như số tiền rút hoặc gửi không hợp lệ.
        Trong vòng lặp chính, khi người dùng nhập số tiền gửi hoặc rút, chúng ta kiểm tra xem người dùng có nhập đúng kiểu dữ liệu không (sử dụng float để chuyển đổi). Nếu không, chương trình sẽ bắt ngoại lệ ValueError và thông báo lỗi.
