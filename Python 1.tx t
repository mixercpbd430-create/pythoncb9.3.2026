    print("Không tìm thấy khuôn mặt trong ảnh.")
else:
    for (x, y, w, h) in faces:
        cv2.rectangle(image, (x, y), (x+w, y+h), (255, 0, 0), 3)

# Hiển thị ảnh
cv2.imshow("Detected Face", image)
cv2.waitKey(0)
cv2.destroyAllWindows()
